# PostersPlus environment configuration
# Copy this file to .env and fill in your values.
# All variables are optional

# =============================================================================
# Server Side Keys (if not set, must be passed by users in URL as parameter)
# =============================================================================

# [Required] TMDB API key — fetches posters, logos, and metadata.
# Get one free at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# [Required] MDBList API key — fetches aggregated ratings and keywords.
# Get one free at https://mdblist.com/
MDBLIST_API_KEY=

# Optional second MDBList API key. When the primary key is rate-limited,
# PostersPlus automatically rotates to this key and back, so ratings
# remain available even during peak usage.
MDBLIST_API_KEY_2=

# =============================================================================
# Access control
# =============================================================================

# Shared secret appended to every request as ?access_key=<value>.
# Leave blank to allow unauthenticated access.
ACCESS_KEY=

# =============================================================================
# Server
# =============================================================================

# Number of Uvicorn worker processes.
# Recommended: 1-2 for home use, up to (2 x CPU cores) for heavy load.
# Increase as required for large/public instances.

WORKERS=2

# =============================================================================
# AIOStreams integration (quality badges)
# =============================================================================

# Base URL of your AIOStreams instance, e.g. http://aiostreams:3000 (bypass authelia, docker network) or https://aiostreams.example.com 
# Leave blank to disable quality badges.
AIOSTREAMS_URL=

# AIOStreams config uuid:password encoded as Base64, include the colon. Suggested that you use a seperate config for this.
AIOSTREAMS_AUTH=

# Days to cache quality data for titles older than 2 weeks.
# New titles always use a 1-day TTL. Increase to reduce AIOStreams traffic.
QUALITY_OLD_CACHE_DURATION=90

# Max concurrent background quality fetches.
# Caps burst load when many uncached titles appear at once.
# More checks still happen, they just wait in a queue.
QUALITY_BG_CONCURRENCY=5

# =============================================================================
# CDN / caching
# =============================================================================

# Adds Cache-Control: public, max-age=<N> to poster responses.
# Set to 0 to disable (default; recommended unless you're using a CDN).
CDN_CACHE_TTL=0

# JPEG output quality for composited posters (70–95). Higher = larger files.
# Default: 85. Raise to 92 for pixel-peepers; lower to 75 to reduce storage/bandwidth.
JPEG_QUALITY=85

# Seconds to keep a composited poster before re-rendering.
# Default: 604800 (7 days)
# Pruning happens automatically based on this value to avoid an evergrowing cache of dead content when users abandon configs
COMPOSITE_CACHE_TTL=604800

# Maximum composite poster cache entries. 0 = no cap (rely on TTL alone).
# I suggest setting this on a public instance, as a failsafe.
COMPOSITE_MAX_ENTRIES=0

# Disable composite poster caching entirely. Every request re-renders from
# scratch. Only use this during development — never in production.
# DISABLE_COMPOSITE_CACHE=true

# =============================================================================
# Logo rendering
# =============================================================================

# When a flat (single-colour) logo's average colour is too close to the poster
# background, recolour it (white / black / complementary accent) so it stays
# legible. Multi-colour and outline logos are never touched. Experimental and
# off by default while it's tested — it can mis-handle some logos. Set to true
# to enable. Default: false.
# LOGO_CONTRAST_RESCUE=false

# Logo fill-stretch: a slim logo whose clamped size leaves it looking lost is
# enlarged toward its size cap by up to this factor (one axis only). 1.0 = no
# enlargement. Only applies when stretching is enabled (see below). Default: 1.2.
# LOGO_STRETCH_FACTOR=1.2
# Fill-stretch is OFF by default (every logo kept at its true clamped size). Set
# to false to enable the stretch described above. Default: true.
# LOGO_STRETCH_DISABLED=true

# Emit per-logo sizing telemetry (source dims, aspect, final dims) at INFO level.
# Handy when tuning logo size; noisy in normal operation. Default: false.
# DEBUG_LOGO_SIZING=false

# Detect burned-in title text on posters TMDB mislabelled as "textless" and skip
# compositing our own logo so the title isn't doubled. Uses the EAST scene-text
# detector — the ~96MB model is downloaded once, on first use, into the cache
# volume. On by default; set to false to opt out. Default: true.
# TEXTLESS_TEXT_DETECTION=true
# Only run detection on titles with at most this many TMDB votes (mislabels
# concentrate in the long tail; popular titles are trusted). This is also the
# main throttle on how much of your library gets the (expensive) CV scan:
# ~300 (default) covers the niche tail (foreign/old/obscure titles) while
# excluding anything mainstream; ~100 scans less but misses legitimately niche
# titles; 1000 is broad (scans mid-tier titles too). Default: 300.
# TEXTLESS_DETECTION_MAX_VOTES=300
# Minimum EAST text activations (at the 320x640 reference, auto-scaled to the
# active resolution) before a poster is treated as having burned-in text. Higher
# = stricter. Default 128 is a conservative balance — ignores a small amount of
# incidental text (signage, vehicle lettering) without missing real titles too
# often; lower toward 48 to catch more marginal text. Changing this
# auto-invalidates cached detection results + composites. Default: 128.
# TEXTLESS_MIN_BOXES=128
# Max text scans allowed into the thread pool at once. Detection is already
# serialised internally, so the default of 1 keeps the rest of the worker pool
# free for compositing during a burst (stops a niche cold pass stalling other
# posters). Only raise on many-core hosts. Default: 1.
# TEXTLESS_DETECTION_CONCURRENCY=1
# EAST scan input resolution (each a multiple of 32). Smaller = faster, roughly
# linearly. Default 192x384 is ~2.7x faster than 320x640 at ~98% identical
# decisions on a real poster sample; 256x512 is ~1.5x at ~99.3%; 320x640 matches
# the reference exactly. min_boxes auto-scales to the resolution, so
# TEXTLESS_MIN_BOXES keeps its meaning. Changing these auto-invalidates cached
# detection results + composites.
# EAST_INPUT_WIDTH=192
# EAST_INPUT_HEIGHT=384
# Fraction of poster height skipped from the TOP before counting title text.
# Titles can sit top/middle/bottom, so this scans almost the whole poster; the
# small default margin ignores studio/network bugs at the very edge. Raise it if
# top-edge logos cause false positives; 0 scans the entire poster. Default: 0.08.
# TEXTLESS_SCAN_TOP=0.08
# BUILD-TIME ONLY (read by compose at `docker compose build`): bake the ~96MB
# EAST model into the image so detection works with no runtime download. Default
# true. Set false for a lean image that downloads the model once at first use.
# BAKE_EAST_MODEL=true

# =============================================================================
# Localisation
# =============================================================================

# ISO 639-1 language code for title logos (e.g. en, fr, de, ja).
# Falls back to English if the preferred language is unavailable.
# This can also be passed in the URL as a parameter (see web configurator)
DEFAULT_LOGO_LANGUAGE=en
